---
import AppLayout from '../layouts/AppLayout.astro';
import { homedir } from 'node:os';
import { join } from 'node:path';
import { readdir, readFile } from 'node:fs/promises';

type Screenshot = {
  key: string;
  url: string;
  file: string;
  imageUrl?: string;
};

type Manifest = {
  run: string | null;
  timestamp: string | null;
  screenshots: Screenshot[];
};

const manifest: Manifest = await latestManifest();

function labelFor(key: string): string {
  return key.split('-').map((part) => part[0]?.toUpperCase() + part.slice(1)).join(' ');
}

async function latestManifest(): Promise<Manifest> {
  const screenshotsDir = join(homedir(), 'syntra/docs/design/screenshots');
  const entries = await readdir(screenshotsDir, { withFileTypes: true }).catch(() => []);
  const runs = entries
    .filter((entry) => entry.isDirectory())
    .map((entry) => entry.name)
    .sort((a, b) => b.localeCompare(a));

  for (const run of runs) {
    try {
      const data = JSON.parse(await readFile(join(screenshotsDir, run, 'manifest.json'), 'utf8')) as Manifest;
      return {
        ...data,
        screenshots: Array.isArray(data.screenshots)
          ? data.screenshots.map((item) => ({
              ...item,
              imageUrl: `/api/design-image/${encodeURIComponent(run)}/${encodeURIComponent(item.file)}`,
            }))
          : [],
      };
    } catch {
      // Try the next newest run.
    }
  }

  return { run: null, timestamp: null, screenshots: [] };
}
---
<AppLayout title="Design" page="design">
    <section class="panel panel-wide" aria-labelledby="design-heading">
      <div class="section-head">
        <div>
          <div class="label" id="design-heading">design screenshots</div>
          <h1 class="design-title">SYNTRA</h1>
        </div>
        <div class="section-head-right">
          {manifest.run ? <span class="badge badge-blue">{manifest.run}</span> : <span class="badge badge-yellow">no run</span>}
          {manifest.timestamp ? <span class="badge badge-muted">{manifest.timestamp}</span> : null}
          <button id="run-review-btn" class="review-btn">run ai review</button>
          <span id="review-status" class="review-status" hidden></span>
        </div>
      </div>

      <details id="review-log-details" class="review-log-wrap">
        <summary class="review-log-toggle">reviewer log</summary>
        <pre id="review-log" class="review-log-pre">loading…</pre>
      </details>

      {manifest.screenshots.length > 0 ? (
        <div class="design-grid">
          {manifest.screenshots.map((shot) => (
            <a class="design-shot" href={shot.imageUrl} target="_blank" rel="noreferrer">
              <img src={shot.imageUrl} alt={`${labelFor(shot.key)} screenshot`} width="1280" height="900" loading="lazy" />
              <span class="design-shot-meta">
                <strong>{labelFor(shot.key)}</strong>
                <span>{shot.url}</span>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="state-entry">No screenshot manifest found.</p>
      )}
    </section>
  </main>

  <style>
    .design-title {
      margin: 0;
      color: var(--blue);
      font-size: 1.35rem;
      line-height: 1;
    }

    .badge-blue {
      color: var(--blue);
    }

    .design-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
    }

    .design-shot {
      display: grid;
      gap: 8px;
      color: var(--text);
      text-decoration: none;
    }

    .design-shot:hover strong,
    .design-shot:focus-visible strong {
      color: var(--blue);
    }

    .design-shot img {
      width: 100%;
      aspect-ratio: 1280 / 900;
      display: block;
      border: 1px solid #262626;
      background: #050505;
      object-fit: cover;
    }

    .design-shot-meta {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
      font-size: 0.76rem;
      line-height: 1.4;
    }

    .design-shot-meta span {
      color: var(--muted);
      overflow-wrap: anywhere;
      text-align: right;
    }

    @media (max-width: 720px) {
      .design-shot-meta {
        display: grid;
        gap: 3px;
      }

      .design-shot-meta span {
        text-align: left;
      }
    }
  </style>
  <style>
    .review-btn {
      font: inherit;
      font-size: 0.76rem;
      background: none;
      border: 1px solid #333;
      color: var(--text);
      padding: 3px 10px;
      border-radius: 3px;
      cursor: pointer;
    }
    .review-btn:hover { border-color: var(--blue); color: var(--blue); }
    .review-btn:disabled { opacity: 0.4; cursor: default; }
    .review-status { font-size: 0.76rem; color: var(--muted); }
    .review-log-wrap { margin-bottom: 16px; }
    .review-log-toggle { font-size: 0.76rem; color: var(--muted); cursor: pointer; list-style: none; user-select: none; }
    .review-log-toggle:hover { color: var(--text); }
    .review-log-pre {
      margin-top: 8px; padding: 10px 12px;
      background: #080808; border: 1px solid #1a1a1a; border-radius: 3px;
      font-size: 0.72rem; line-height: 1.5; color: var(--muted);
      white-space: pre-wrap; overflow-wrap: anywhere;
      max-height: 200px; overflow-y: auto;
    }
  </style>
  <script define:vars={{ currentRun: manifest.run ?? '' }}>
    async function pollDesignScreenshots() {
      try {
        const response = await fetch('/api/design-screenshots', { cache: 'no-store' });
        if (!response.ok) return;

        const payload = await response.json();
        if (payload.run && payload.run !== currentRun) {
          location.reload();
        }
      } catch {
        // Keep polling; the screenshot service may be between runs.
      }
    }

    setInterval(pollDesignScreenshots, 15_000);

    const logEl = document.getElementById('review-log');
    const logDetails = document.getElementById('review-log-details');
    async function refreshLog() {
      if (!logDetails.open) return;
      try {
        const res = await fetch('/api/design-review-log', { cache: 'no-store' });
        if (res.ok) logEl.textContent = (await res.json()).log || '(empty)';
      } catch {}
    }
    logDetails?.addEventListener('toggle', refreshLog);
    setInterval(refreshLog, 3_000);
    refreshLog();

    const runBtn = document.getElementById('run-review-btn');
    const statusEl = document.getElementById('review-status');

    runBtn?.addEventListener('click', async () => {
      runBtn.disabled = true;
      statusEl.textContent = 'running…';
      statusEl.hidden = false;
      try {
        const res = await fetch('/api/design-review', { method: 'POST' });
        if (res.ok) {
          statusEl.textContent = 'check telegram';
        } else {
          statusEl.textContent = 'error — check aperture logs';
        }
      } catch {
        statusEl.textContent = 'network error';
      }
      setTimeout(() => {
        runBtn.disabled = false;
        statusEl.hidden = true;
      }, 10_000);
    });
  </script>
</AppLayout>
