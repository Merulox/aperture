---
import '../styles/global.css';
import { getTaskboardData } from '../lib/tasks';

const { permissionRequests, exTasks, syntraTasks, brainBus } = await getTaskboardData();
const activeExTasks = exTasks.filter((task) => task.status !== 'done');
const doneExTasks = exTasks.filter((task) => task.status === 'done');
const groupedSyntra = Object.groupBy(syntraTasks, (task) => task.status);
const attentionStatuses = ['review', 'backlog', 'briefed'];
const otherStatuses = Object.keys(groupedSyntra)
  .filter((status) => !attentionStatuses.includes(status) && status !== 'done')
  .sort();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tasks · Aperture</title>
</head>
<body>
  <main>
    <header class="topbar">
      <div class="brand">aperture / tasks</div>
      <div class="taskboard-meta">
        <span>Last updated: {new Date().toLocaleTimeString('en-CA', { hour: '2-digit', minute: '2-digit', second: '2-digit' })}</span>
        <a href="/" class="nav-link">dashboard</a>
      </div>
    </header>

    <div class="taskboard">
      <section class="panel" id="codex-instances-panel" aria-labelledby="codex-heading">
        <div class="section-head">
          <div class="label" id="codex-heading">codex instances</div>
          <span class="badge badge-muted" id="codex-count">0 running</span>
        </div>
        <div id="codex-jobs-list">
          <p class="state-entry">— no active instances —</p>
        </div>
      </section>

      <section class="panel" aria-labelledby="requests-heading">
        <div class="section-head">
          <div class="label" id="requests-heading">permission requests</div>
          <span class={`badge ${permissionRequests.length ? 'badge-red' : 'badge-muted'}`}>
            {permissionRequests.length} pending
          </span>
        </div>
        <div class="request-list">
          {
            permissionRequests.length ? permissionRequests.map((request) => (
              <div class={`request-card urgency-${request.urgency}`}>
                <div class="request-meta">{request.requestor} · {request.task} · {request.created}</div>
                <div class="request-question">{request.question}</div>
                {request.context && <div class="request-context">{request.context}</div>}
                <form method="POST" action="/api/respond" class="request-form">
                  <input type="hidden" name="id" value={request.id} />
                  <textarea name="answer" placeholder="Your answer..." required></textarea>
                  <button type="submit">Respond</button>
                </form>
              </div>
            )) : <p class="state-entry">— no pending permission requests —</p>
          }
        </div>
      </section>

      <section class="panel" aria-labelledby="ex-heading">
        <div class="section-head">
          <div class="label" id="ex-heading">ex tasks</div>
          <span class="badge badge-muted">{exTasks.length} tasks</span>
        </div>
        <div class="ex-grid">
          {
            activeExTasks.length ? activeExTasks.map((task) => (
              <div class={`ex-task ${task.uninitiated ? 'task-uninitiated' : ''}`}>
                <span class="task-id">{task.id}</span>
                <span class={`badge badge-${task.statusTone}`}>{task.statusBadge}</span>
                <span class="task-title">{task.title}</span>
                <span class="task-note">{task.riskGate || '—'}</span>
                {task.prompt && (
                  <div class="prompt-block">
                    <pre>{task.prompt}</pre>
                    <div class="prompt-actions">
                      <button type="button" class="copy-prompt" data-prompt={task.prompt}>Copy prompt</button>
                      {task.status === 'briefed' && (
                        <button
                          type="button"
                          class="launch-codex"
                          data-task-id={task.id}
                          data-task-title={task.title}
                          data-brief-path={task.briefPath}
                          data-prompt={task.prompt}
                        >
                          Send to Codex
                        </button>
                      )}
                    </div>
                  </div>
                )}
                {task.briefPath && (
                  <details class="brief-preview">
                    <summary>▶ View brief</summary>
                    <pre>{task.briefExists ? task.briefPreview : `Brief not found at ${task.briefPath}`}</pre>
                  </details>
                )}
              </div>
            )) : <p class="state-entry">— no active ex tasks —</p>
          }
          <details class="done-group ex-done-group">
            <summary>[{doneExTasks.length} done — click to expand]</summary>
            <div class="ex-grid">
              {doneExTasks.map((task) => (
                <div class="ex-task">
                  <span class="task-id">{task.id}</span>
                  <span class={`badge badge-${task.statusTone}`}>{task.statusBadge}</span>
                  <span class="task-title">{task.title}</span>
                  <span class="task-note">{task.riskGate || '—'}</span>
                  {task.briefPath && (
                    <details class="brief-preview">
                      <summary>▶ View brief</summary>
                      <pre>{task.briefExists ? task.briefPreview : `Brief not found at ${task.briefPath}`}</pre>
                    </details>
                  )}
                </div>
              ))}
            </div>
          </details>
        </div>
      </section>

      <section class="panel" aria-labelledby="syntra-heading">
        <div class="section-head">
          <div class="label" id="syntra-heading">syntra</div>
          <span class="badge badge-muted">{syntraTasks.length} tasks</span>
        </div>
        <div class="syntra-groups">
          {attentionStatuses.map((status) => (
            <section class="syntra-group attention-group">
              <h2>{status} <span class="badge badge-yellow">{groupedSyntra[status]?.length || 0}</span></h2>
              {
                groupedSyntra[status]?.length ? (
                  <div class="task-list">
                    {groupedSyntra[status]?.map((task) => (
                      <div class={`task-row ${task.uninitiated ? 'task-uninitiated' : ''}`}>
                        <span class="task-id">{task.id}</span>
                        <span class={`badge badge-${task.statusTone}`}>{task.statusBadge}</span>
                        <span class="task-title">{task.title}</span>
                        <span class="task-note">{task.notes}</span>
                        {task.prompt && (
                          <div class="prompt-block">
                            <pre>{task.prompt}</pre>
                            <div class="prompt-actions">
                              <button type="button" class="copy-prompt" data-prompt={task.prompt}>Copy prompt</button>
                              {task.status === 'briefed' && (
                                <button
                                  type="button"
                                  class="launch-codex"
                                  data-task-id={task.id}
                                  data-task-title={task.title}
                                  data-brief-path={task.briefPath}
                                  data-prompt={task.prompt}
                                >
                                  Send to Codex
                                </button>
                              )}
                            </div>
                          </div>
                        )}
                        {task.briefPath && (
                          <details class="brief-preview">
                            <summary>▶ View brief</summary>
                            <pre>{task.briefExists ? task.briefPreview : `Brief not found at ${task.briefPath}`}</pre>
                          </details>
                        )}
                      </div>
                    ))}
                  </div>
                ) : <p class="state-entry">— none —</p>
              }
            </section>
          ))}
          {otherStatuses.map((status) => (
            <section class="syntra-group">
              <h2>{status} <span class="badge badge-muted">{groupedSyntra[status]?.length || 0}</span></h2>
              <div class="task-list">
                {groupedSyntra[status]?.map((task) => (
                  <div class="task-row">
                    <span class="task-id">{task.id}</span>
                    <span class={`badge badge-${task.statusTone}`}>{task.statusBadge}</span>
                    <span class="task-title">{task.title}</span>
                    <span class="task-note">{task.notes}</span>
                    {task.briefPath && (
                      <details class="brief-preview">
                        <summary>▶ View brief</summary>
                        <pre>{task.briefExists ? task.briefPreview : `Brief not found at ${task.briefPath}`}</pre>
                      </details>
                    )}
                  </div>
                ))}
              </div>
            </section>
          ))}
          <details class="syntra-group done-group">
            <summary>[{groupedSyntra.done?.length || 0} done — click to expand]</summary>
            {
              groupedSyntra.done?.length ? (
                <div class="task-list">
                  {groupedSyntra.done.map((task) => (
                      <div class="task-row">
                        <span class="task-id">{task.id}</span>
                        <span class={`badge badge-${task.statusTone}`}>{task.statusBadge}</span>
                        <span class="task-title">{task.title}</span>
                        <span class="task-note">{task.notes}</span>
                        {task.briefPath && (
                          <details class="brief-preview">
                            <summary>▶ View brief</summary>
                            <pre>{task.briefExists ? task.briefPreview : `Brief not found at ${task.briefPath}`}</pre>
                          </details>
                        )}
                    </div>
                  ))}
                </div>
              ) : <p class="state-entry">— none —</p>
            }
          </details>
        </div>
      </section>

      <section class="panel" aria-labelledby="brain-heading">
        <div class="section-head">
          <div class="label" id="brain-heading">brain bus</div>
          <span class="badge badge-muted">queue</span>
        </div>
        <div class="queue-counts">
          <div><span class="queue-number">{brainBus.pending}</span><span>pending</span></div>
          <div><span class="queue-number">{brainBus.claimed}</span><span>claimed</span></div>
          <div><span class="queue-number">{brainBus.failed}</span><span>failed</span></div>
        </div>
        {
          brainBus.failedTasks.length > 0 && (
            <div class="failed-list">
              <div class="label">failed tasks</div>
              {brainBus.failedTasks.map((task) => (
                <div class="failed-task">
                  <span class="badge badge-red">{task.priority}</span>
                  <span>{task.action}</span>
                </div>
              ))}
            </div>
          )
        }
      </section>
    </div>
  </main>
  <script>
    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function elapsed(startedAt, finishedAt) {
      const end = finishedAt ? new Date(finishedAt) : new Date();
      const ms = end - new Date(startedAt);
      const s = Math.floor(ms / 1000);
      return s < 60 ? `${s}s` : `${Math.floor(s / 60)}m ${s % 60}s`;
    }

    async function loadJobs() {
      const response = await fetch('/api/codex-jobs');
      const { jobs = [] } = await response.json();
      const panel = document.getElementById('codex-jobs-list');
      const count = document.getElementById('codex-count');

      const runningJobs = jobs.filter((job) => job.status === 'running');
      const finishedJobs = jobs.filter((job) => job.status !== 'running');
      count.textContent = `${runningJobs.length} running`;

      // Sync launch buttons: mark any task with a running job as in-progress
      const runningByTaskId = new Map(runningJobs.map((j) => [j.taskId, j]));
      document.querySelectorAll<HTMLButtonElement>('.launch-codex').forEach((btn) => {
        const running = runningByTaskId.get(btn.dataset.taskId || '');
        if (running) {
          btn.textContent = `Running (PID ${running.pid})`;
          btn.disabled = true;
        } else if (btn.disabled && btn.textContent !== 'Launching...') {
          btn.textContent = 'Send to Codex';
          btn.disabled = false;
        }
      });

      if (!jobs.length) {
        panel.innerHTML = '<p class="state-entry">— no active instances —</p>';
        return;
      }

      function jobRow(job: any) {
        return `
          <div class="codex-job status-${job.status}">
            <span class="task-id">${escapeHtml(job.taskId)}</span>
            <span class="badge badge-${job.status === 'running' ? 'blue' : job.status === 'done' ? 'muted' : 'red'}">${escapeHtml(job.status.toUpperCase())}</span>
            <span class="task-title">${escapeHtml(job.taskTitle)}</span>
            <span class="elapsed">${escapeHtml(elapsed(job.startedAt, job.finishedAt))}</span>
            <pre class="job-log" id="log-${job.jobId}">${escapeHtml(job.logTail || '(no output yet)')}</pre>
          </div>`;
      }

      const wasOpen = panel.querySelector('details[data-key="completed"]')?.hasAttribute('open') ?? false;

      const runningHtml = runningJobs.map(jobRow).join('');
      const finishedHtml = finishedJobs.length
        ? `<details class="done-group" data-key="completed"${wasOpen ? ' open' : ''}><summary>[${finishedJobs.length} completed — click to expand]</summary>${finishedJobs.map(jobRow).join('')}</details>`
        : '';

      panel.innerHTML = (runningHtml || '<p class="state-entry">— no running instances —</p>') + finishedHtml;

      // Auto-scroll running job logs to bottom
      panel.querySelectorAll<HTMLElement>('.status-running .job-log').forEach((el) => {
        el.scrollTop = el.scrollHeight;
      });
    }

    loadJobs();
    window.setInterval(loadJobs, 5_000);

    document.querySelectorAll<HTMLButtonElement>('.copy-prompt').forEach((button) => {
      button.addEventListener('click', async () => {
        await navigator.clipboard.writeText(button.dataset.prompt || '');
        button.textContent = 'Copied ✓';
        window.setTimeout(() => {
          button.textContent = 'Copy prompt';
        }, 2_000);
      });
    });

    document.querySelectorAll<HTMLFormElement>('.request-form').forEach((form) => {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const fields = Object.fromEntries(new FormData(form));
        if (submit) submit.disabled = true;
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(fields),
        });
        if (response.ok) {
          window.location.assign('/tasks');
          return;
        }
        if (submit) submit.disabled = false;
        window.alert(await response.text());
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.launch-codex').forEach((button) => {
      button.addEventListener('click', async () => {
        button.disabled = true;
        button.textContent = 'Launching...';

        try {
          const response = await fetch('/api/launch-codex', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              taskId: button.dataset.taskId,
              taskTitle: button.dataset.taskTitle,
              briefPath: button.dataset.briefPath,
              prompt: button.dataset.prompt,
            }),
          });
          const result = await response.json();

          if (response.ok) {
            button.textContent = `Launched (PID ${result.pid})`;
            window.setTimeout(() => loadJobs(), 1000);
            return;
          }
        } catch {
          // Handled below.
        }

        button.textContent = 'Failed';
        button.disabled = false;
      });
    });
  </script>
</body>
</html>
