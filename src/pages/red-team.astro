  </style>

  <script>
    const status = document.getElementById('hack-status');

    document.querySelectorAll<HTMLButtonElement>('.copy-command').forEach((button) => {
      button.addEventListener('click', async () => {
        const command = button.dataset.command ?? '';
        try {
          await navigator.clipboard.writeText(command);
          button.textContent = 'copied';
          setTimeout(() => { button.textContent = 'copy'; }, 1200);
        } catch {
          if (status) status.textContent = 'clipboard unavailable — select the command manually';
        }
      });
    });

    document.getElementById('refresh-proof')?.addEventListener('click', () => location.reload());

    document.querySelectorAll<HTMLButtonElement>('.workspace-select').forEach((button) => {
      button.addEventListener('click', async () => {
        button.disabled = true;
        const response = await fetch('/api/red-team', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ action: 'workspace', workspaceId: button.dataset.workspace }),
        });
        if (response.ok) location.reload();
        else {
          const result = await response.json();
          if (status) status.textContent = result.error ?? 'workspace update failed';
          button.disabled = false;
        }
      });
    });

    let category = 'all';
    const search = document.querySelector<HTMLInputElement>('#tool-search');
    const tools = [...document.querySelectorAll<HTMLElement>('.tool')];
    function filterTools() {
      const query = search?.value.trim().toLowerCase() ?? '';
      for (const tool of tools) {
        const categoryMatches = category === 'all' || tool.dataset.category === category;
        const queryMatches = !query || tool.dataset.search?.includes(query);
        tool.hidden = !categoryMatches || !queryMatches;
      }
    }
    document.querySelectorAll<HTMLButtonElement>('.tool-filter').forEach((button) => {
      button.addEventListener('click', () => {
        category = button.dataset.category ?? 'all';
        document.querySelectorAll('.tool-filter').forEach((item) => item.classList.remove('selected'));
        button.classList.add('selected');
        filterTools();
      });
    });
    search?.addEventListener('input', filterTools);
  </script>
</AppLayout>
