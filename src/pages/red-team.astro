    .method li>span { display:grid; place-items:center; width:18px; height:18px; border:1px solid #314252; color:#78a8d0; font-size:.55rem; }
    .method strong,.method small { display:block; }
    .method strong { color:#abb6c1; font-size:.63rem; }
    .method small { margin-top:2px; color:#596571; font-size:.55rem; line-height:1.4; }
    .side-block { display:grid; gap:8px; margin-top:17px; padding-top:15px; border-top:1px solid #252b31; }
    .side-block>strong { color:#bdc7d0; font-size:.71rem; }
    .side-block>code { color:#7dacd4; font-size:.56rem; overflow-wrap:anywhere; }
    .side-block>p { margin:0; color:#6c7884; font-size:.6rem; line-height:1.55; }
