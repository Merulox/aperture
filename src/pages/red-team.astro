    .data-model>div { display:grid; grid-template-columns:7px 55px 1fr; gap:7px; align-items:center; }
    .data-model i { width:5px; height:5px; }.data-model i.raw { background:#c17960; }.data-model i.normalized { background:#6292bd; }.data-model i.evidence { background:#61bb7f; }
